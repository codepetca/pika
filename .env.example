# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# Session (generate with: npm run generate:secret)
# Should be 64 hex characters (0-9, a-f only)
SESSION_SECRET=generate-a-secure-random-secret-with-npm-run-generate-secret

# Auth Configuration
# Comma-separated list of teacher emails for development
DEV_TEACHER_EMAILS=teacher@example.com,admin@yrdsb.ca

# Email Configuration
# For development: set ENABLE_MOCK_EMAIL=true to log codes to console
# For production/staging: set ENABLE_MOCK_EMAIL=false and configure Brevo
ENABLE_MOCK_EMAIL=true

# Brevo (Sendinblue) - for production email sending
# Get API key from: https://app.brevo.com/settings/keys/api
# Template ID from: https://app.brevo.com/camp/lists/template
BREVO_API_KEY=
BREVO_TEMPLATE_ID=2
BREVO_FROM_EMAIL=noreply@notify.codepet.ca
BREVO_FROM_NAME=Pika

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# UI Gallery (dev/staging)
ENABLE_UI_GALLERY=false

# Cron (Vercel Cron Jobs)
# Vercel will send this value as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=generate-a-secure-random-secret

# AI (optional)
# Used for AI grading, log summaries, and developer feedback extraction
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=
OPENAI_DEVELOPER_FEEDBACK_MODEL=

# Gradex smoke integration (optional)
# Used by `pnpm smoke:gradex` to submit sanitized sample assignment data to Gradex.
GRADEX_API_URL=http://localhost:3000
GRADEX_API_KEY=
GRADEX_INTERNAL_TOKEN=
GRADEX_SMOKE_POLL_ATTEMPTS=20
GRADEX_SMOKE_POLL_INTERVAL_MS=1500

# Gradex assignment grading integration (optional, disabled by default)
# When true, assignment background auto-grade runs submit sanitized data to Gradex
# instead of grading each item directly inside Pika.
GRADEX_ASSIGNMENT_GRADING_ENABLED=false
CLASSROOM_ARCHIVE_EXPORT_ENABLED=false
CLASSROOM_ARCHIVE_EXPORT_TEACHER_IDS=
CLASSROOM_ARCHIVE_RESTORE_ENABLED=false
CLASSROOM_ARCHIVE_RESTORE_TEACHER_IDS=
# Set to the plan/project database quota. Free plan default is 500 MiB (524288000 bytes).
CLASSROOM_ARCHIVE_RESTORE_DATABASE_BUDGET_BYTES=
# Server-only classroom Gradex extract canary. Keep disabled until migration 084 is applied.
CLASSROOM_GRADEX_EXTRACT_ENABLED=false
CLASSROOM_GRADEX_EXTRACT_TEACHER_IDS=
# At least 32 bytes. Rotation intentionally invalidates in-progress idempotency keys.
CLASSROOM_GRADEX_EXTRACT_HMAC_SECRET=
# Separate teacher-route canary. Both this flag and the exact source archive UUID are required.
CLASSROOM_GRADEX_TRIGGER_ENABLED=false
CLASSROOM_GRADEX_TRIGGER_ARCHIVE_IDS=
# Server-only retention worker. No route or schedule invokes it by default.
CLASSROOM_GRADEX_CLEANUP_ENABLED=false
GRADEX_PIKA_PSEUDONYM_SALT=

# GitHub API (optional for repo review helpers)
# Token needs `repo` scope, or `public_repo` if the repo is public.
GITHUB_PAT=
GITHUB_FEEDBACK_TOKEN=

# Dangerous operations (scripts)
# Required to run `npm run seed:fresh` (it wipes data).
ALLOW_DB_WIPE=false

# Dev endpoints (development only)
# Required to enable /api/dev/* endpoints like reseed
ALLOW_DEV_ENDPOINTS=true
