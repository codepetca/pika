{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "git": {
    "deploymentEnabled": {
      "main": true,
      "production": true,
      "*": false
    }
  },
  "crons": [
    {
      "path": "/api/cron/nightly-log-summaries",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-history",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/assignment-artifact-storage-cleanup",
      "schedule": "30 7 * * *"
    }
  ]
}
